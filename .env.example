# Prisma CLI connection (from `npx prisma dev`)
DATABASE_URL="postgresql://user:password@localhost:5432/ngo_hub"

# Direct Postgres URL for Prisma Client (required for app runtime)
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/ngo_hub"

# --- Production (Supabase example) ---
# Direct (use for BOTH vars on Hostinger, or at least DIRECT_DATABASE_URL):
# DIRECT_DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
# Or classic direct host:
# DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"
# DATABASE_URL can be the same string as DIRECT_DATABASE_URL

# JWT secrets — generate strong random strings for production
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Production app URL (required on Hostinger for links, cookies, HR enrollment)
NEXT_PUBLIC_APP_URL="https://svitech.in"

# Optional: Free AI report generation (uses one if set; falls back to template)
# Groq free tier: https://console.groq.com/
GROQ_API_KEY=""
# Google Gemini free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=""

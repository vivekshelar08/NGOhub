# --- Local development ---
# Prisma CLI connection (from `npx prisma dev` or your local Postgres)
DATABASE_URL="postgresql://user:password@localhost:5432/ngo_hub"

# Direct Postgres URL for Prisma Client at runtime (same as DATABASE_URL locally)
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/ngo_hub"

# --- Production (Supabase Postgres) ---
# Supabase → Connect → Pooler → Session mode, port 5432 (IPv4-friendly for most hosts)
# DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
# DIRECT_DATABASE_URL="postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:5432/postgres"
#
# Or direct connection (IPv6; use pooler if your host cannot reach db.*.supabase.co):
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"
# DIRECT_DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres"
#
# URL-encode special characters in the password (@ → %40, # → %23, % → %25)
# Supabase → Database → Network → allow all IPs (0.0.0.0/0)

# Supabase JS client (optional — storage, realtime; auth uses custom JWT)
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# JWT secrets — generate strong random strings for production
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"

# Public app URL (required in production for links, cookies, HR enrollment, password reset)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Hostinger) — used for password reset and notifications
# Create a mailbox in Hostinger → Emails, then use these SMTP settings:
# SMTP_HOST="smtp.hostinger.com"
# SMTP_PORT="465"
# SMTP_USER="your-name@yourdomain.com"
# SMTP_PASSWORD="your-email-password"
# SMTP_FROM="your-name@yourdomain.com"

# Optional: Advanced AI impact reporting engine (uses one provider; falls back to template)
# Force provider: openai | groq | gemini (auto-detects if unset)
AI_ENGINE_PROVIDER=""
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
# Groq free tier: https://console.groq.com/
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
# Google Gemini free tier: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
